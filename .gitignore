# =============================================================================
# Iter — .gitignore
# =============================================================================

# Credentials and local configuration (NEVER commit these)
config.json
secrets.json
.env
*.env

# Windows Registry Files (from Windows Integration)
*.reg

# Unused and obsolete folders
Unused/

# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging artifacts
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/

# IDEs and editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# Project local test files and outputs
test_doc.md
test_out.md
*test_out*
*_preprocessed.md
*_postprocessed.md
*_processed.md

# Agent and MCP workspace caches (Temporary)
.system_generated/
.agents/
